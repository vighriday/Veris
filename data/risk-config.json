{
  "$schema": "veris://schema/risk-config.v1",
  "description": "Tunable weights and constants for risk scoring, confidence math, budget allocation, and workflow criticality. Override at .veris/data/risk-config.json. Every number visible and explainable.",
  "risk": {
    "blastRadiusPerEdge": 8,
    "blastRadiusMax": 100,
    "fragilityLog2Coefficient": 18,
    "criticalityBase": 30,
    "criticalityEnginePatternBonus": 25,
    "criticalityHighImpactPatternBonus": 35,
    "criticalityHighImpactPathBonus": 20,
    "criticalityMax": 100,
    "weights": {
      "blastRadius": 0.45,
      "runtimeCriticality": 0.35,
      "dependencyFragility": 0.2
    },
    "patterns": {
      "enginePattern": "(engine|service|processor|orchestrat|handler|controller|gateway)",
      "highImpactPattern": "(auth|login|signin|signup|oauth|session|password|token|payment|charge|refund|billing|invoice|checkout|order|webhook|migrate|migration|encrypt|decrypt|secret)",
      "highImpactPathSegments": ["engine", "mcp", "persistence", "auth", "authn", "authz", "payments", "billing", "webhooks", "checkout", "queue"]
    }
  },
  "confidence": {
    "halfLifeDays": 14,
    "tierWeight": { "Tier 1": 1, "Tier 2": 2, "Tier 3": 4 },
    "riskPenaltyCoefficient": 0.4,
    "missingExecutionPenaltyCoefficient": 0.5,
    "failurePenaltyPerTierWeight": 6,
    "flakyHalfCreditPenalty": 2,
    "failurePenaltyCap": 40,
    "fragilityAssumptionThreshold": 60
  },
  "budget": {
    "tierLeverage": { "Tier 1": 1, "Tier 2": 3, "Tier 3": 7 },
    "tierCostSeconds": { "Tier 1": 5, "Tier 2": 30, "Tier 3": 120 },
    "workflowCriticality": {
      "Payments": 2.0, "Authentication": 2.0, "Authorization": 1.8, "Webhooks": 1.8,
      "Billing": 1.7, "Checkout": 1.7, "Session": 1.6, "Persistence": 1.5,
      "Queue": 1.5, "Sync": 1.4, "Orchestration": 1.4, "Realtime": 1.3,
      "Caching": 1.2, "Notifications": 1.1, "AI": 1.5, "Routing": 1.4,
      "Cart": 1.2, "Search": 1.0, "Profile": 0.9, "Admin": 1.2, "Analytics": 0.8,
      "Onboarding": 1.0, "Reporting": 0.7, "Configuration": 0.7, "Infrastructure": 0.8,
      "Core": 1.0, "Uncategorized": 0.7
    }
  }
}
